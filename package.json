{
  "name": "codebase-docs",
  "version": "1.0.0",
  "description": "Interactive codebase documentation generator",
  "main": "dist/cli.js",
  "bin": {
    "codebase-docs": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "documentation",
    "codebase",
    "visualization",
    "dependency-graph"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  }
}
